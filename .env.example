# Copy this file to .env and set secure values.

# Path to the recipies folder
RECIPIES_PATH=recipies

# Optional basic auth credentialss
# HTTP_BASIC_USER=user
# HTTP_BASIC_PASSWORD=pass

# Neo4j admin password used by both neo4j and mcp server.
NEO4J_PASSWORD=change-me

# Optional tool namespace prefix for MCP tools.
# Example tool name with default value: local-read_neo4j_cypher
NEO4J_NAMESPACE=local

# Penpot database password
PENPOT_DB_PASSWORD=change-me-db

# Penpot secret key for session encryption
PENPOT_SECRET_KEY=change-me-secret-key
